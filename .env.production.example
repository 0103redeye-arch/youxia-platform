# ============================================================
# 貼到 Vercel Dashboard → Settings → Environment Variables
# 每一行 = 一個變數，= 左邊是 Key，右邊是 Value
# 標註 [你填] 的才需要動，其餘直接複製貼上
# ============================================================

# ── 資料庫（從 .env.local 複製）────────────────────────────
DATABASE_URL=【從 .env.local 複製】
DIRECT_URL=【從 .env.local 複製】

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL=https://【你填：你的 Vercel 網域，例如 youxia-platform.vercel.app】
AUTH_SECRET=wPJa2tUEAKgVbbUNqmVYzIrgC1iYwJc3wsk6yX4DtwE

# ── Google OAuth（從 .env.local 複製）──────────────────────────
AUTH_GOOGLE_CLIENT_ID=【從 .env.local 複製】
AUTH_GOOGLE_CLIENT_SECRET=【從 .env.local 複製】

# ── App URL（和 NEXTAUTH_URL 一樣的網域）────────────────────
NEXT_PUBLIC_APP_URL=https://【你填：同上網域】

# ── Cron 保護 ────────────────────────────────────────────────
CRON_SECRET=b46861701bc5c4358312703a471f07de409028b7bd266481

# ── LINE Login（有要開才填）──────────────────────────────────
# AUTH_LINE_CLIENT_ID=
# AUTH_LINE_CLIENT_SECRET=

# ── UploadThing 圖片上傳（有要開才填）───────────────────────
# UPLOADTHING_SECRET=
# UPLOADTHING_APP_ID=

# ── Twilio SMS（有要開才填）─────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15017122661

# ── ECPay 綠界（有要開才填，留空 = 自動測試模式）────────────
# ECPAY_ENV=production
# ECPAY_MERCHANT_ID=
# ECPAY_HASH_KEY=
# ECPAY_HASH_IV=
